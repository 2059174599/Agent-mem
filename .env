# agent-mem 环境变量配置文件
# 根据 config.py 中的默认值配置

# ==================== 部署模式配置 ====================
# 部署模式：source(源码部署) | docker(Docker部署)
DEPLOY_MODE=source

# Docker部署时是否包含ES和Redis服务
# 设置为false时，仅启动API服务，通过环境变量连接外部ES和Redis
DOCKER_INCLUDE_ES_REDIS=false

# ==================== 应用配置 ====================
APP_ENV=production
DEBUG=false
APP_PORT=8000
APP_HOST=0.0.0.0

# ==================== ES配置 ====================
# 单节点配置
ES_HOST=http://localhost:9200
# 集群配置（可选，优先级高于ES_HOST）
# ES_HOSTS=http://es1:9200,http://es2:9200,http://es3:9200
ES_USERNAME=elastic
ES_PASSWORD=difyai123456
ES_CHAT_INDEX=aigc_user_dialogs

# ES安全配置
ES_SECURITY_ENABLED=false
ES_JAVA_OPTS="-Xms512m -Xmx512m"

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=difyai123456
REDIS_DB=2

# ==================== LLM配置 ====================
LLM_BASE_URL=http://aigc-api.aigc.paas.corp/v1/chat/completions
LLM_API_KEY=sk-ftmE4M3322c945i6A3TONZk8Oe2Op7nB1hChD3029EJGLX1A
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=30
LLM_RETRY_COUNT=3
LLM_RETRY_DELAY=1.0

# ==================== Embedding配置 ====================
EMBEDDING_BASE_URL=http://aigc-api.aigc.paas.test/v1/embeddings
EMBEDDING_API_KEY=sk-YC9Utxm3F4WBjQqFWCwuU9Tdk26i45zDa6637w7rTc3WyvYP
EMBEDDING_MODEL=bge-m3
EMBEDDING_TIMEOUT=30
EMBEDDING_RETRY_COUNT=3
EMBEDDING_RETRY_DELAY=1.0
BGE_M3_DIMS=1024

# ==================== 缓存配置 ====================
EMBEDDING_CACHE_TTL=5184000
EMBEDDING_CACHE_TTL_MIN=2592000
EMBEDDING_CACHE_TTL_MAX=7776000

# ==================== 搜索配置 ====================
# 搜索阈值配置
SEARCH_THRESHOLD_KEYWORD=0.01
SEARCH_THRESHOLD_TOPIC=0.1
SEARCH_THRESHOLD_CONTENT=0.05
SEARCH_THRESHOLD_SEMANTIC=0.15

# 搜索权重配置
SEARCH_WEIGHT_TOPIC=0.4
SEARCH_WEIGHT_KEYWORD=0.3
SEARCH_WEIGHT_CONTENT=0.2
SEARCH_WEIGHT_TIME_7D=0.1

# Redis事实搜索策略 - 默认关闭，直接返回全部事实
SEARCH_ENABLE_LLM_SEMANTIC=false
SEARCH_ENABLE_TOPIC=false
SEARCH_ENABLE_KEYWORD=false
SEARCH_ENABLE_SEMANTIC=false
SEARCH_ENABLE_TIME_RANKING=false
SEARCH_ENABLE_FUZZY=false
SEARCH_REDIS_RETURN_ALL_FACTS=false

# 搜索结果配置
SEARCH_MAX_RESULTS=50
SEARCH_FACT_COUNT_THRESHOLD=50
SEARCH_RECENT_CHATS_LIMIT=20

# LLM搜索配置（当启用时使用）
SEARCH_LLM_TIMEOUT=30
SEARCH_LLM_TEMPERATURE=0.1

# ==================== 答案质量检测配置 ====================
# 是否启用质量检测（默认启用）
QUALITY_CHECK_ENABLED=true
# 最小答案长度
QUALITY_CHECK_MIN_LENGTH=10
# 最大重复比例（0.0-1.0）
QUALITY_CHECK_MAX_REPETITION=0.3
# 最大语气助词比例（0.0-1.0）
QUALITY_CHECK_MAX_INTERJECTION=0.7
# 最小相关性分数（0.0-1.0）
QUALITY_CHECK_MIN_RELEVANCE=0.3
# 最小LLM评分（0.0-1.0）
QUALITY_CHECK_MIN_LLM_SCORE=0.3

# ==================== 事实管理配置 ====================
FACT_ENABLE_LLM_JUDGMENT=true
FACT_SIMILARITY_THRESHOLD=0.1
FACT_ENABLE_AUTO_MERGE=true
FACT_MERGE_SEPARATOR=；
FACT_TIMESTAMP_FORMAT=[提及于{timestamp}]

FACT_ENABLE_DUPLICATE_CHECK=true
FACT_MAX_LENGTH=1000
FACT_ENABLE_COMPRESSION=false
FACT_BACKUP_ENABLED=true

# ==================== 系统配置 ====================
SIMILARITY_THRESHOLD=0.6
MAX_SEARCH_RESULTS=10

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/app.log

# ==================== 性能配置 ====================
REQUEST_TIMEOUT=30
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY=1

# ==================== 文本处理配置 ====================
PUNCTUATION_PATTERN=[？?！!。，,、；;：:""''（）()【】\\[\\]《》<>]
TEXT_CLEANING_ENABLED=true
