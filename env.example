# yaxin_memo 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ==================== 部署模式配置 ====================
# 部署模式：full(完整部署) | app-only(仅应用)
DEPLOY_MODE=full

# 是否部署ES服务
DEPLOY_ES=true

# 是否部署Redis服务
DEPLOY_REDIS=true

# 是否部署Kibana服务
DEPLOY_KIBANA=true

# ==================== 应用配置 ====================
APP_ENV=production
DEBUG=false
APP_PORT=5010
APP_HOST=0.0.0.0

# ==================== ES配置 ====================
# 当使用外部ES服务时，请修改以下配置
# 单节点配置
ES_HOST=http://elasticsearch:9200
# 集群配置（可选，优先级高于ES_HOST）
# ES_HOSTS=http://es1:9200,http://es2:9200,http://es3:9200
ES_USERNAME=elastic
ES_PASSWORD=changeme
ES_CHAT_INDEX=aigc_user_dialogs

# ES安全配置（仅当DEPLOY_ES=true时生效）
ES_SECURITY_ENABLED=false
ES_JAVA_OPTS="-Xms512m -Xmx512m"

# ==================== Redis配置 ====================
# 当使用外部Redis服务时，请修改以下配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2

# ==================== LLM配置 ====================
LLM_BASE_URL=http://aigc-api.aigc.paas.corp/v1/chat/completions
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-5
LLM_TIMEOUT=30
LLM_RETRY_COUNT=3
LLM_RETRY_DELAY=1.0

# ==================== Embedding配置 ====================
EMBEDDING_BASE_URL=http://aigc-api.aigc.paas.test/v1/embeddings
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_MODEL=bge-m3
EMBEDDING_TIMEOUT=30
EMBEDDING_RETRY_COUNT=3
EMBEDDING_RETRY_DELAY=1.0
BGE_M3_DIMS=1024

# ==================== 搜索配置 ====================
SEARCH_THRESHOLD_KEYWORD=0.01
SEARCH_THRESHOLD_TOPIC=0.1
SEARCH_THRESHOLD_CONTENT=0.05
SEARCH_THRESHOLD_SEMANTIC=0.15

SEARCH_WEIGHT_TOPIC=15.0
SEARCH_WEIGHT_SUBTOPIC=12.0
SEARCH_WEIGHT_CONTENT=10.0
SEARCH_WEIGHT_KEYWORD=2.0
SEARCH_WEIGHT_TIME_7D=3.0
SEARCH_WEIGHT_TIME_30D=1.0

# Redis事实搜索策略 - 默认关闭，直接返回全部事实
SEARCH_ENABLE_LLM_SEMANTIC=false
SEARCH_ENABLE_TOPIC=false
SEARCH_ENABLE_KEYWORD=false
SEARCH_ENABLE_SEMANTIC=false
SEARCH_ENABLE_TIME_RANKING=false
SEARCH_ENABLE_FUZZY=false
SEARCH_REDIS_RETURN_ALL_FACTS=true

# 搜索结果配置
SEARCH_MAX_RESULTS=50
SEARCH_FACT_COUNT_THRESHOLD=50
SEARCH_RECENT_CHATS_LIMIT=20

# LLM搜索配置（当启用时使用）
SEARCH_LLM_TIMEOUT=30
SEARCH_LLM_TEMPERATURE=0.1

# ==================== 答案质量检测配置 ====================
# 是否启用质量检测（默认启用）
QUALITY_CHECK_ENABLED=true
# 最小答案长度
QUALITY_CHECK_MIN_LENGTH=10
# 最大重复比例（0.0-1.0）
QUALITY_CHECK_MAX_REPETITION=0.3
# 最大语气助词比例（0.0-1.0）
QUALITY_CHECK_MAX_INTERJECTION=0.7
# 最小相关性分数（0.0-1.0）
QUALITY_CHECK_MIN_RELEVANCE=0.3
# 最小LLM评分（0.0-1.0）
QUALITY_CHECK_MIN_LLM_SCORE=0.3

# ==================== 事实管理配置 ====================
FACT_ENABLE_LLM_JUDGMENT=false
FACT_SIMILARITY_THRESHOLD=0.1
FACT_ENABLE_AUTO_MERGE=true
FACT_MERGE_SEPARATOR=；
FACT_TIMESTAMP_FORMAT=[提及于{timestamp}]

FACT_ENABLE_DUPLICATE_CHECK=true
FACT_MAX_LENGTH=1000
FACT_ENABLE_COMPRESSION=false
FACT_BACKUP_ENABLED=true

# ==================== 主题配置（可选，用逗号分隔） ====================
# TOPIC_HOBBY=电影,音乐,阅读,运动,游戏,旅行,美食,摄影
# TOPIC_PERSONAL=姓名,年龄,职业,教育背景,家庭状况,联系方式
# TOPIC_WORK=工作内容,技能特长,项目经验,职业规划,工作习惯
# TOPIC_LIFESTYLE=作息时间,饮食习惯,运动习惯,消费习惯,学习习惯
# TOPIC_EMOTION=性格特点,价值观,兴趣爱好,社交偏好,情感状态
# TOPIC_LEARNING=学习目标,学习方法,知识领域,技能提升,成长经历
# TOPIC_RELATIONSHIP=朋友关系,家庭关系,同事关系,恋人关系,社交圈子
# TOPIC_HEALTH=身体状况,疾病历史,用药情况,检查结果,治疗方案

# ==================== 关键词配置（可选，用逗号分隔） ====================
# KEYWORDS_HOBBY=喜欢,爱好,兴趣,热爱,享受,沉迷,擅长,精通,经常,总是,习惯
# KEYWORDS_PERSONAL=姓名,年龄,职业,教育,家庭,联系,电话,邮箱,地址,生日,星座,血型,叫,名字,称呼,身份,角色,自称
# KEYWORDS_WORK=工作,职业,技能,项目,经验,规划,习惯,公司,职位,薪资,同事,老板,客户,上班
# KEYWORDS_LIFESTYLE=作息,饮食,运动,消费,学习,起床,睡觉,吃饭,洗澡,刷牙,锻炼,健身,每天,经常
# KEYWORDS_EMOTION=性格,价值观,社交,情感,心情,感受,想法,态度,观点,信念,原则,觉得,认为,叫,名字,称呼,自称,助手,AI,机器人,偏好,喜欢,希望,想要
# KEYWORDS_LEARNING=学习,读书,课程,培训,技能,知识,成长,进步,目标,计划,反思,提升,掌握
# KEYWORDS_RELATIONSHIP=朋友,家人,同事,恋人,社交,关系,沟通,相处,理解,支持,帮助,信任,关心
# KEYWORDS_HEALTH=健康,身体,疾病,症状,医生,医院,药物,治疗,检查,康复,预防,感觉,不适

# ==================== 同义词配置（可选，用逗号分隔） ====================
# SYNONYMS_MOVIE=片子,影片,影视,cinema,movie,film
# SYNONYMS_MUSIC=歌曲,歌,曲子,music,song,旋律
# SYNONYMS_WORK=职业,上班,打工,job,work,career
# SYNONYMS_STUDY=读书,上课,培训,study,learn,教育
# SYNONYMS_SPORT=锻炼,健身,跑步,exercise,sport,活动
# SYNONYMS_FRIEND=好友,伙伴,buddy,friend,同伴
# SYNONYMS_FAMILY=亲人,家庭成员,family,亲属
# SYNONYMS_HEALTH=身体,体质,health,physical,状况
# SYNONYMS_PERSONALITY=个性,脾气,personality,character,性情
# SYNONYMS_HABIT=习性,惯例,habit,routine,规律
# SYNONYMS_LIKE=爱好,热爱,享受,沉迷,擅长,精通
# SYNONYMS_OFTEN=总是,习惯,每天,定期,频繁
# SYNONYMS_FEEL=觉得,认为,感受,体验,察觉
# SYNONYMS_RELATION=联系,关联,连接,纽带,桥梁
# SYNONYMS_AGE=多大了,岁,多大,几岁,年纪,年岁,你多大了,几岁了
# SYNONYMS_SIZE=年龄,岁,几岁,年纪,年岁,多大了,你多大了
# SYNONYMS_HOW_OLD=年龄,岁,多大,年纪,年岁,多大了,你多大了
# SYNONYMS_HOW_OLD_QUESTION=年龄,岁,多大,几岁,年纪,年岁,你几岁,几岁了
# SYNONYMS_AGE_QUESTION=年龄,岁,多大,几岁,年纪,年岁,几岁了

# ==================== 语义模式配置（可选，用逗号分隔） ====================
# SEMANTIC_MOVIE=科幻,动作,喜剧,恐怖,爱情,剧情,悬疑,动画,纪录片,战争
# SEMANTIC_MUSIC=流行,摇滚,古典,爵士,民谣,电子,说唱,蓝调,乡村,朋克
# SEMANTIC_WORK=编程,设计,销售,管理,客服,分析,运营,市场,财务,人事
# SEMANTIC_STUDY=编程,语言,数学,历史,科学,艺术,哲学,心理学,经济学,文学
# SEMANTIC_SPORT=跑步,游泳,健身,篮球,足球,瑜伽,网球,高尔夫,滑雪,骑行
# SEMANTIC_PERSONALITY=内向,外向,乐观,悲观,冷静,热情,谨慎,冒险,理性,感性
# SEMANTIC_FOOD=中餐,西餐,日料,韩料,火锅,烧烤,甜点,饮料,水果,零食
# SEMANTIC_TRAVEL=国内,国外,海边,山区,城市,乡村,古镇,海岛,沙漠,森林

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ==================== 性能配置 ====================
REQUEST_TIMEOUT=10
MAX_RETRY_ATTEMPTS=2
RETRY_DELAY=1
CACHE_TTL=3600
MAX_CACHE_SIZE=1000

# ==================== 相似度配置 ====================
SIMILARITY_THRESHOLD=0.6
MAX_SEARCH_RESULTS=20

# ==================== 内容压缩配置 ====================
# 是否启用自动内容压缩（在事实提取/合并时自动压缩过长内容）
COMPRESSION_ENABLED=true
# 技术类内容压缩阈值（字符数）
COMPRESSION_TECH_THRESHOLD=200
# 通用类内容压缩阈值（字符数）
COMPRESSION_GENERAL_THRESHOLD=300

# ==================== 持久化配置 ====================
# 是否启用持久化功能
PERSISTENCE_ENABLED=true
# 持久化后端类型: es(Elasticsearch) 或 file(本地文件)
PERSISTENCE_BACKEND=file
# 持久化间隔（秒），0表示每次修改后立即持久化，建议300（5分钟）
PERSISTENCE_INTERVAL=300
# 持久化文件存储目录（仅当PERSISTENCE_BACKEND=file时有效）
PERSISTENCE_DATA_DIR=data/persistence
# 持久化ES索引名称（仅当PERSISTENCE_BACKEND=es时有效）
PERSISTENCE_ES_INDEX=user_memory_facts
